# Copy to .env.production before running production compose in WSL
# Required model/API keys should be copied from your working .env

BETTER_AUTH_SECRET=replace-with-64-hex-chars
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:2026
NEXT_PUBLIC_LANGGRAPH_BASE_URL=http://localhost:2026/api/langgraph
NEXT_PUBLIC_STATIC_WEBSITE_ONLY=false
LANGCHAIN_TRACING_V2=false

POSTGRES_DB=deerflow
POSTGRES_USER=deerflow
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_CONNECTION_STRING=postgresql://deerflow:replace-with-strong-password@postgres:5432/deerflow?sslmode=disable

# Copy the rest of the required provider credentials from .env
# OPENAI_API_KEY=...
# DASHSCOPE_API_KEY=...
# ANTHROPIC_API_KEY=...

# Optional path overrides for WSL production
DEER_FLOW_HOME=/root/deerflow/runtime/fork/backend/.deer-flow
DEER_FLOW_CONFIG_PATH=/root/deerflow/runtime/fork/config.production.yaml
DEER_FLOW_EXTENSIONS_CONFIG_PATH=/root/deerflow/runtime/fork/extensions_config.production.json
DEER_FLOW_DOCKER_SOCKET=/var/run/docker.sock
DEER_FLOW_REPO_ROOT=/root/deerflow/runtime/fork

# The default production config targets a model proxy on the WSL host at host.docker.internal:8787.
# If your proxy listens elsewhere, update config.production.yaml before deploy.

