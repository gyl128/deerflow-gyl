{
  "mcpServers": {
    "knowledge-distiller": {
      "enabled": false,
      "type": "stdio",
      "command": "python3",
      "args": [
        "/root/.openclaw-wsl-track-a/workspace/agents/video-distiller/server.py",
        "--model",
        "qwen-pool/coder-model",
        "--stdio"
      ],
      "env": {
        "BILIBILI_COOKIE_FILE": "/root/.openclaw-wsl-track-a/cookies/bilibili.txt"
      },
      "description": "Video knowledge distillation for Bilibili and YouTube"
    },
    "filesystem": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/path/to/allowed/files"
      ],
      "env": {},
      "description": "Provides filesystem access within allowed directories"
    },
    "github": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_TOKEN": "$GITHUB_TOKEN"
      },
      "description": "GitHub MCP server for repository operations"
    },
    "postgres": {
      "enabled": false,
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/mydb"
      ],
      "env": {},
      "description": "PostgreSQL database access"
    }
  },
  "skills": {}
}
