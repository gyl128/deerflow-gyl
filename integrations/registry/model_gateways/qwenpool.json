{
  "id": "qwenpool",
  "kind": "model_gateway",
  "display_name": "QwenPool Gateway",
  "description": "OpenAI-compatible pooled gateway for qwen.ai profiles with short-queue protection and local SSE synthesis.",
  "protocol": "openai",
  "health_url": "http://host.docker.internal:8787/health",
  "status_url": "http://host.docker.internal:8787/status",
  "base_url": "http://host.docker.internal:8787/v1",
  "compatibility": {
    "agent_centers": [
      "deerflow",
      "openclaw"
    ]
  },
  "models": [
    {
      "name": "qwen-code",
      "display_name": "Qwen Coder (Local)",
      "provider_model": "openai:coder-model",
      "api_key_env": "QWENPOOL_API_KEY",
      "api_key_fallback": "sk-dummy",
      "max_tokens": 4096,
      "temperature": 0.7,
      "supports_thinking": true,
      "supports_vision": false
    }
  ],
  "targets": {
    "deerflow": {
      "config_section": "models"
    }
  }
}
